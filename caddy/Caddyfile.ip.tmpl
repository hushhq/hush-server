# Caddy configuration template for IP-only self-hosted Hush instances
# Processed by scripts/setup.sh --ip: __IP__ is replaced at setup time.
# Do NOT edit this file directly - edit the template and re-run setup.sh.
#
# Uses Caddy's internal CA for self-signed TLS. Browsers will show a certificate
# warning on first visit - this is expected. E2EE is unaffected; the self-signed
# cert only protects the transport layer between browser and server.

{
  # Clients connecting to an IP address don't send SNI (RFC 6066 - SNI is
  # hostname-only). Without this fallback, Caddy can't match the request to a
  # site block and the TLS handshake fails with an internal error.
  default_sni __IP__
}

https://__IP__ {
  tls internal

  # LiveKit WebSocket signaling - no security headers to avoid breaking upgrade handshake
  handle /livekit* {
    uri strip_prefix /livekit
    reverse_proxy livekit:7880 {
      header_up Connection {http.request.header.Connection}
      header_up Upgrade {http.request.header.Upgrade}
    }
  }

  # Go API
  handle /api/* {
    reverse_proxy hush-api:8080
  }

  # Go WebSocket
  handle /ws {
    reverse_proxy hush-api:8080 {
      header_up Connection {http.request.header.Connection}
      header_up Upgrade {http.request.header.Upgrade}
    }
  }

  # Informational fallback for browser visits. hush-server does not bundle the
  # browser client or admin UI; connect with a compatible Hush web client.
  handle {
    header X-Content-Type-Options "nosniff"
    header X-Frame-Options "DENY"
    header Cross-Origin-Opener-Policy "same-origin"
    respond "Hush instance backend is live. Use a compatible Hush web client and connect to this instance URL. The browser admin UI is not bundled by hush-server." 200
  }

  log {
    output stdout
    format console
  }
}
