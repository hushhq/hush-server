# Caddy configuration template for self-hosted Hush instances
# Processed by scripts/setup.sh: __DOMAIN__, __RTC_DOMAIN__, and __EMAIL__ are replaced at setup time.
# Do NOT edit this file directly - edit the template and re-run setup.sh.
#
# Auto-HTTPS: Caddy obtains and renews TLS certificates via Let's Encrypt automatically.
# Requirement: __DOMAIN__, __RTC_DOMAIN__, and storage.__DOMAIN__ must point
# to this server on ports 80 and 443 before startup.

{
  email __EMAIL__
}

__DOMAIN__ {
  # Legacy same-domain LiveKit signaling. Production clients receive
  # wss://__RTC_DOMAIN__/ from /api/livekit/token; keep this route for
  # older clients and local migrations that still target /livekit/.
  handle /livekit* {
    uri strip_prefix /livekit
    reverse_proxy livekit:7880 {
      header_up Connection {http.request.header.Connection}
      header_up Upgrade {http.request.header.Upgrade}
    }
  }

  # Go API
  handle /api/* {
    reverse_proxy hush-api:8080
  }

  # Go WebSocket
  handle /ws {
    reverse_proxy hush-api:8080 {
      header_up Connection {http.request.header.Connection}
      header_up Upgrade {http.request.header.Upgrade}
    }
  }

  # Admin dashboard (embedded in Go binary)
  handle /admin* {
    reverse_proxy hush-api:8080
  }

  # Informational fallback for browser visits.
  handle {
    header X-Content-Type-Options "nosniff"
    header X-Frame-Options "DENY"
    header Cross-Origin-Opener-Policy "same-origin"
    header Strict-Transport-Security "max-age=31536000; includeSubDomains"
    respond "Hush instance backend is live. Use a compatible Hush web client and connect to this instance URL, or visit /admin/ for the instance admin dashboard." 200
  }

  log {
    output stdout
    format console
  }
}

# LiveKit signaling. This dedicated hostname is part of the production
# self-host contract so Safari/iCloud Private Relay does not have to
# negotiate LiveKit WebSockets through a Cloudflare-proxied app path.
__RTC_DOMAIN__ {
  reverse_proxy livekit:7880 {
    header_up Connection {http.request.header.Connection}
    header_up Upgrade {http.request.header.Upgrade}
  }

  log {
    output stdout
    format console
  }
}

# Device-link bulk transfer storage: presigned-URL endpoint for the
# MinIO backend. Requires a DNS A record `storage.__DOMAIN__` pointing
# at this server. The browser PUTs/GETs ciphertext directly here via
# presigned URLs minted by the API; chunks never traverse the API
# process.
#
# CORS is enforced by MinIO at the bucket level (see scripts/setup.sh
# bootstrap step), not by Caddy, because the SDK signature includes
# Host + path and any header-rewriting middleware could break it.
storage.__DOMAIN__ {
  reverse_proxy minio:9000

  log {
    output stdout
    format console
  }
}
