# Hush Go API -Environment Variables
# Copy to .env for running the Go server locally (outside Docker).
# When running via docker-compose, env vars are set in docker-compose.yml.

# Server
PORT=8080

# Database
DATABASE_URL=postgres://hush:hush@localhost:5432/hush?sslmode=disable

# Auth
JWT_SECRET=dev-jwt-secret-change-in-production

# CORS -set to your frontend URL in production
CORS_ORIGIN=http://localhost:5173

# LiveKit
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_URL=ws://localhost:7880
