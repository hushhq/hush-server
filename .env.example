# Hush API environment variables.
# Copy to .env for local/manual runs.
# docker-compose.prod.yml also reads this file via env_file.

# Runtime
PRODUCTION=false
HOST=127.0.0.1
PORT=8080
JWT_EXPIRY_HOURS=168

# Public origin
DOMAIN=localhost
CORS_ORIGIN=http://localhost:5173

# Database
DATABASE_URL=postgres://hush:hush@localhost:5432/hush?sslmode=disable

# Auth and admin
JWT_SECRET=dev-jwt-secret-change-in-production
ADMIN_API_KEY=dev-admin-api-key-change-in-production

# LiveKit
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_URL=ws://localhost:7880

# Key transparency
# 32-byte Ed25519 seed, hex-encoded. Persist this value forever once the log
# has entries; changing it invalidates historical verification.
TRANSPARENCY_LOG_PRIVATE_KEY=
