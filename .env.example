# Hush Go API environment variables
# Copy to .env for local development or self-hosted setup.

# Server
PORT=8080

# Database
DATABASE_URL=postgres://hush:hush@localhost:5432/hush?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# User auth
JWT_SECRET=dev-jwt-secret-change-in-production

# Instance admin control plane
ADMIN_BOOTSTRAP_SECRET=dev-admin-bootstrap-secret-change-in-production
ADMIN_SESSION_TTL_HOURS=24

# Instance service identity
SERVICE_IDENTITY_MASTER_KEY=dev-service-identity-master-key-change-in-production

# Key transparency
TRANSPARENCY_LOG_PRIVATE_KEY=

# Instance policy
REGISTRATION_MODE=open

# CORS
CORS_ORIGIN=http://localhost:5173

# LiveKit
LIVEKIT_HOST=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
