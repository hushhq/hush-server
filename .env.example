# Hush API environment variables.
# Copy to .env for local/manual runs.
# docker-compose.prod.yml also reads this file via env_file.

# Runtime
PRODUCTION=false
HOST=127.0.0.1
PORT=8080
JWT_EXPIRY_HOURS=168

# Public origin
DOMAIN=localhost
# For backend-only self-hosting with the official hosted client, use:
# CORS_ORIGIN=https://app.gethush.live
CORS_ORIGIN=http://localhost:5173

# Database
DATABASE_URL=postgres://hush:hush@localhost:5432/hush?sslmode=disable
JWT_SECRET=dev-jwt-secret-change-in-production

# Instance admin
ADMIN_BOOTSTRAP_SECRET=dev-admin-bootstrap-secret-change-in-production
ADMIN_SESSION_TTL_HOURS=24
SERVICE_IDENTITY_MASTER_KEY=dev-service-identity-master-key-change-in-production

# LiveKit
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_URL=ws://localhost:7880

# Key transparency
# 32-byte Ed25519 seed, hex-encoded. Persist this value forever once the log
# has entries; changing it invalidates historical verification.
TRANSPARENCY_LOG_PRIVATE_KEY=

# --- Device-link bulk transfer storage --------------------------------------
# Pluggable backend for chunked archive transfer in /api/auth/link-archive-*.
#   postgres_bytea  Default. No external service. Suitable for tiny self-host
#                   installs; chunks live in Postgres BYTEA. Has the same
#                   reverse-proxy body-limit constraints as the prior
#                   in-API path.
#   s3              Production. Chunks live in an S3-compatible bucket;
#                   browser PUTs/GETs presigned URLs directly, never
#                   traversing the API process. Requires the STORAGE_S3_*
#                   vars below.
STORAGE_BACKEND=postgres_bytea

# When STORAGE_BACKEND=s3 these are required:
STORAGE_S3_ENDPOINT=         # e.g. storage.example.com (no scheme); for AWS S3: s3.us-east-1.amazonaws.com
STORAGE_S3_REGION=us-east-1
STORAGE_S3_BUCKET=hush-link-archive
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=
STORAGE_S3_USE_SSL=true      # false for plain HTTP MinIO without TLS

# --- Self-host MinIO --------------------------------------------------------
# Only used when the bundled MinIO service runs (see docker-compose.prod.yml).
# setup.sh generates these and writes the matching STORAGE_S3_* values.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_SERVER_URL=            # e.g. https://storage.example.com — must match the public URL the browser hits

# --- Operational containment for the bulk plane -----------------------------
# Per-user concurrent active archives (default 1). Raise carefully; each
# active archive can hold up to LINK_ARCHIVE_STAGING_BYTES_CAP / quota bytes.
LINK_ARCHIVE_USER_QUOTA=1
# Per-instance ceiling on total bytes summed across non-terminal archives.
# Default: 8 GiB.
LINK_ARCHIVE_STAGING_BYTES_CAP=8589934592
# Auto-supersede grace window (seconds). At /link-archive-init the server
# tears down any prior active archive owned by the same user whose last
# sliding-expiry refresh predates this window. Default 1800 (30 min) is
# longer than the slowest realistic single-chunk download so a
# genuinely-active concurrent session is not preempted.
LINK_ARCHIVE_SUPERSEDE_GRACE_SECONDS=1800

# Origin allowed by the bucket CORS policy. Match your hush-web deployment.
# setup.sh defaults this to https://app.gethush.live for self-host installs
# that point at the official client.
STORAGE_BROWSER_ORIGIN=https://app.gethush.live
